      "name": "ADD POLICIES",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// ✅ Check status code\r",
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "// ✅ Parse response JSON\r",
              "let jsonData = pm.response.json();\r",
              "\r",
              "// ✅ Ensure response is not empty\r",
              "pm.test(\"Response is not empty\", function () {\r",
              "    pm.expect(jsonData).to.not.be.empty;\r",
              "});\r",
              "\r",
              "// ✅ Verify policy object created\r",
              "pm.test(\"Policy object created\", function () {\r",
              "    pm.expect(jsonData.id).to.exist;\r",
              "    pm.expect(jsonData.policyNumber).to.exist;\r",
              "});\r",
              "\r",
              "// ✅ Verify customer details exist\r",
              "pm.test(\"Customer details exist\", function () {\r",
              "    pm.expect(jsonData.customer).to.have.property(\"name\");\r",
              "});\r",
              "\r",
              "// ✅ Verify vehicle details exist\r",
              "pm.test(\"Vehicle details exist\", function () {\r",
              "    pm.expect(jsonData.vehicle).to.have.property(\"make\");\r",
              "    pm.expect(jsonData.vehicle).to.have.property(\"model\");\r",
              "    pm.expect(jsonData.vehicle).to.have.property(\"year\");\r",
              "    pm.expect(jsonData.vehicle).to.have.property(\"vin\");\r",
              "});\r",
              "\r",
              "// ✅ Verify coverage details exist\r",
              "pm.test(\"Coverage details exist\", function () {\r",
              "    pm.expect(jsonData.coverage).to.have.property(\"type\");\r",
              "    pm.expect(jsonData.coverage).to.have.property(\"liabilityLimit\");\r",
              "    pm.expect(jsonData.coverage).to.have.property(\"collisionDeductible\");\r",
              "    pm.expect(jsonData.coverage).to.have.property(\"comprehensiveDeductible\");\r",
              "});\r",
              "\r",
              "// ✅ Verify discounts exist\r",
              "pm.test(\"Discounts exist\", function () {\r",
              "    pm.expect(jsonData.discounts).to.have.property(\"safeDriver\");\r",
              "    pm.expect(jsonData.discounts).to.have.property(\"multiPolicy\");\r",
              "});\r",
              "\r",
              "// ✅ Save important values into environment for later use\r",
              "pm.environment.set(\"policyId\", jsonData.id);\r",
              "pm.environment.set(\"policyNumber\", jsonData.policyNumber);\r",
              "pm.environment.set(\"customerName\", jsonData.customer.name);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
